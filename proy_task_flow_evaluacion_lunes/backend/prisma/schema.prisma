// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Usuario {
  id                 Int        @id @default(autoincrement())
  nombreU             String
  email              String     @unique
  password           String
  creadoEn           DateTime   @default(now())
  proyectos          Proyecto[] @relation("ProyectoCreador")
  proyectosEditados  Proyecto[] @relation("ProyectoEditor")
  tareas             Tarea[]

  @@map("usuarios")
}

model Proyecto {
  id               Int       @id @default(autoincrement())
  nombre           String
  descripcion      String?
  creadoEn         DateTime  @default(now())
  actualizadoEn    DateTime? @updatedAt
  usuarioId        Int
  usuario          Usuario   @relation("ProyectoCreador", fields: [usuarioId], references: [id], onDelete: Cascade)
  actualizadoPorId Int?
  actualizadoPor   Usuario?  @relation("ProyectoEditor", fields: [actualizadoPorId], references: [id], onDelete: SetNull)
  tareas           Tarea[]

  @@map("proyectos")
}

model Tarea {
  id          Int      @id @default(autoincrement())
  titulo      String
  descripcion String?
  estado      Estado   @default(PENDIENTE)
  creadoEn    DateTime @default(now())
  proyectoId  Int
  proyecto    Proyecto @relation(fields: [proyectoId], references: [id], onDelete: Cascade)
  usuarioId   Int?
  usuario     Usuario? @relation(fields: [usuarioId], references: [id], onDelete: SetNull)

  @@map("tareas")
}

enum Estado {
  PENDIENTE
  EN_PROGRESO
  COMPLETADA
}
